# =========================================
# АЮРВЕДА БОТ — Змінні оточення (приклад)
# Скопіюйте цей файл як .env і заповніть
# =========================================

# Telegram Bot Token (отримайте від @BotFather у Telegram)
BOT_TOKEN=your_telegram_bot_token_here

# URL вашого Web App (після деплойменту на Render.com)
# Формат: https://your-app-name.onrender.com
WEBAPP_URL=https://your-app-name.onrender.com

# Режим роботи бота: webhook або polling
# На Render.com використовуємо: webhook
# Локально для тестування: polling
BOT_MODE=webhook

# Секретний токен для webhook (будь-який рядок без пробілів)
WEBHOOK_SECRET=your_secret_webhook_token_here

# Порт сервера (Render.com задає автоматично через змінну PORT)
PORT=8080

# Шлях до сховища даних користувачів
STORAGE_PATH=./storage

# Режим розробки (True = детальні логи)
DEBUG=False
